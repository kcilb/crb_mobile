<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 31+: system splash uses SplashScreen API (not only windowBackground). -->
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/launch_bg_soft_start</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launch_screen_icon</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/launch_splash_branding_strip</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
</resources>
